<style>
  /* Ensure body content is not overlapped by navbar */
  body {
    padding-top: 30px; /* Adjust based on navbar height */
   
  }

  /* Ensure navbar is styled properly */
  .navbar {
    z-index: 1000; /* Ensures navbar stays above other content */
    height: 9vh;
  }

  /* Carousel height fix */
  #carouselExample {
    max-height: 70vh; /* Adjust based on preference */
    overflow: hidden;
    margin-top: 41px;
    width: 100%;
    
  }

  .carousel-inner img {
    width: 100%;
    height: 40vh; /* Adjust based on preference */
    object-fit: cover; /* Prevents image stretching */
  }
</style>

<!-- Navbar -->
<nav class="navbar fixed-top navbar-expand-lg navbar-dark" style="background-color:#131A22;">
  <div class="container">
    <a class="navbar-brand" href="/products">
      <i class="fas fa-shopping-basket" style="margin-right: 10px;font-size: 1.7rem; color: white;"></i>
      <h5>Sharda.com</h5>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarTogglerDemo02"
      aria-controls="navbarTogglerDemo02" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarTogglerDemo02">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link" aria-current="page" href="/" style="color: white;"><h5>Home</h5></a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/products" style="color: white;"><h5>Products</h5></a>
        </li>
        <% if(currentUser && currentUser.role === 'seller') { %>
        <li class="nav-item">
          <a class="nav-link" href="/products/new" style="color: white;"><h5>New</h5></a>
        </li>
        <% } %>
      </ul>

      <div>
        <img src="https://logos.textgiraffe.com/logos/logo-name/Sharda-designstyle-candy-m.png" alt="Logo" width="400"
          height="50">
      </div>

      <div class="navbar-nav ml-auto">
        <% if(!currentUser) { %>
        <a href="/login" class="nav-link" style="color: white;"><h5>Login</h5></a>
        <% } else { %>
        <a href="/products" class="nav-link text-capitalize" style="color: white;">
          <h5>Hello, <%=currentUser.username%></h5>
        </a>
        <a href="/user/cart" class="nav-link">
          <i class="fas fa-shopping-cart"></i>
          <sup><span class="badge bg-danger"><%=currentUser.cart.length%></span></sup>
        </a>
        <a href="/logout" class="nav-link" style="color: white;"><h5>Logout</h5></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<!-- Carousel -->
<div id="carouselExample" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-inner">
    <div class="carousel-item active">
      <img src="https://m.media-amazon.com/images/G/31/IMG20/Home/2025/heroslider/February/PC_Hero_Slider_-_Maha_shivratri_store._SX3000_QL85_FMpng_.png" class="d-block w-100" alt="...">
    </div>
    <div class="carousel-item">
      <img src="https://m.media-amazon.com/images/G/31/sthaneka/febherosliders/PC/HG._SX3000_QL85_.jpg" class="d-block w-100" alt="...">
    </div>
    <div class="carousel-item">
      <img src="https://m.media-amazon.com/images/G/31/img18/HomeImprovement/Feb25/HnK/Sliders/HI_Overall_PC._SX3000_QL85_.jpg" class="d-block w-100" alt="...">
    </div>
  </div>
  <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
  </button>
</div>
